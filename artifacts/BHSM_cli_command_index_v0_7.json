{
  "artifact_name": "BHSM CLI Command Index",
  "version": "0.7",
  "entrypoint": "python -m bhsm.interface",
  "commands": [
    {"command": "registry", "purpose": "list prediction registry entries", "output": "text/json"},
    {"command": "status", "purpose": "show one registry entry", "output": "text/json"},
    {"command": "predict", "purpose": "run a deterministic interface demonstration", "output": "text/json"},
    {"command": "report", "purpose": "build a reviewer report", "output": "text/json"},
    {"command": "gallery", "purpose": "build the prediction gallery", "output": "markdown/json"},
    {"command": "plot-gallery", "purpose": "generate or inspect gallery plots", "output": "json/files"},
    {"command": "notebook-pack", "purpose": "inspect parse-only notebooks", "output": "json"},
    {"command": "pdg-status", "purpose": "report optional reference-adapter status", "output": "json"},
    {"command": "pdg-fetch", "purpose": "load a comparison reference with offline fallback", "output": "json"},
    {"command": "speculative", "purpose": "inspect disabled candidate templates", "output": "text/json"},
    {"command": "theorem-blockers", "purpose": "list unresolved theorem objects", "output": "json"},
    {"command": "theorem-attempt", "purpose": "run a fail-closed closure attempt", "output": "text/json"},
    {"command": "artifact-sources", "purpose": "discover local evidence", "output": "text/json"},
    {"command": "formula-registry", "purpose": "list callables and theorem gates", "output": "text/json"},
    {"command": "compute-artifact", "purpose": "load one local artifact", "output": "text/json"},
    {"command": "artifact-predictions", "purpose": "list adapter-backed values", "output": "json"},
    {"command": "artifact-report", "purpose": "build a provenance-aware report", "output": "markdown/json"},
    {"command": "theorem-closure-report", "purpose": "run strict proof-gate attempts", "output": "markdown/json"},
    {"command": "close-theorem", "purpose": "evaluate one theorem", "output": "text/json"},
    {"command": "theorem-proof-gates", "purpose": "show theorem gate results", "output": "text/json"},
    {"command": "cp-o-int-report", "purpose": "run the CP attachment audit", "output": "markdown/json"},
    {"command": "cp-o-int-stages", "purpose": "show CP attachment stages", "output": "json"},
    {"command": "cp-o-int-proof-gates", "purpose": "show focused CP proof gates", "output": "json"},
    {"command": "cp-o-int-candidate", "purpose": "inspect the disabled author template", "output": "json"},
    {"command": "cp-o-int-field-action", "purpose": "build the symbolic field/action report", "output": "markdown/json"},
    {"command": "cp-o-int-field-action-stages", "purpose": "show Sprint C stages", "output": "json"},
    {"command": "cp-o-int-production-eligibility", "purpose": "show production and runtime eligibility", "output": "json"},
    {"command": "cp-o-int-action-candidate", "purpose": "show the symbolic action candidate", "output": "json"}
  ],
  "internet_required": false,
  "pdg_required": false,
  "external_hep_tools_required": false,
  "offline_reference_fallback_available": true,
  "reference_values_used_as_derivation_inputs": false
}
