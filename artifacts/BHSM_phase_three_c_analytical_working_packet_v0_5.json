  "proposed_author_axioms": {
    "BHSM_P4_projection_axiom": {
      "status_if_accepted": "DERIVED_CONDITIONAL_FROM_AUTHOR_AXIOM",
      "text": "The physical 4D fields of BHSM are canonically normalized projections of internal Berger-Hopf boundary modes onto local 4D spacetime sections. The projection preserves the no-fit internal coefficients exported in BHSM v1.0.1. Empirical target values are not used to set the projection map, normalization, or vertex coefficients."
    },
    "BHSM_N_canonical_normalization_axiom": {
      "status_if_accepted": "DERIVED_CONDITIONAL_FROM_AUTHOR_AXIOM",
      "text": "For every projected 4D field, field rescaling is fixed solely by the requirement that the kinetic term take canonical 4D form. Scalar, vector, and fermion kinetic terms are normalized respectively to +1/2 ∂φ∂φ, -1/4 FF, and i ψbar γDψ. Interaction coefficients are rescaled by the inverse square root product of the participating field normalizations."
    },
    "BHSM_V_vertex_lift_axiom": {
      "status_if_accepted": "DERIVED_CONDITIONAL_FROM_AUTHOR_AXIOM",
      "text": "A BHSM boundary/operator coefficient becomes a 4D vertex coefficient only after the corresponding projected fields, Lorentz structure, gauge representation, and canonical normalization factors are specified. Until then, the coefficient is a boundary-source coefficient, not a production FeynRules coupling."
    }
  },
